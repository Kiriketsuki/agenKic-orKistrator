[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/overlays/status_overlay.gd" id="1"]

[node name="StatusOverlay" type="PanelContainer"]
mouse_filter = 2
script = ExtResource("1")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 2
mouse_filter = 2
theme_override_constants/margin_left = 10
theme_override_constants/margin_top = 8
theme_override_constants/margin_right = 10
theme_override_constants/margin_bottom = 8

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
mouse_filter = 2
theme_override_constants/separation = 4

[node name="NameLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
mouse_filter = 2
theme_override_font_sizes/font_size = 15
theme_override_colors/font_color = Color(0.95, 0.92, 0.85, 1)
text = "agent"

[node name="Grid" type="GridContainer" parent="Margin/VBox"]
layout_mode = 2
mouse_filter = 2
columns = 2
theme_override_constants/h_separation = 10
theme_override_constants/v_separation = 2

[node name="ClassCaption" type="Label" parent="Margin/VBox/Grid"]
layout_mode = 2
mouse_filter = 2
theme_override_font_sizes/font_size = 11
theme_override_colors/font_color = Color(0.7, 0.68, 0.62, 1)
text = "Class"

[node name="ClassLabel" type="Label" parent="Margin/VBox/Grid"]
layout_mode = 2
mouse_filter = 2
theme_override_font_sizes/font_size = 11
text = "Apprentice"

[node name="ProviderCaption" type="Label" parent="Margin/VBox/Grid"]
layout_mode = 2
mouse_filter = 2
theme_override_font_sizes/font_size = 11
theme_override_colors/font_color = Color(0.7, 0.68, 0.62, 1)
